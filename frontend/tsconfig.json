{
    "compilerOptions": {
        "target": "es2022",
        "lib": ["es2022", "DOM"],
        "module": "esnext",
        "skipLibCheck": true,

        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,

        "strict": true,
    },

    "include": ["src"]
}